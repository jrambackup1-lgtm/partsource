{
  "name": "partsource-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "scraper": "node scripts/run-scraper.mjs",
    "dev:all": "concurrently -n \"SCRAPER,WEB\" -c \"magenta,cyan\" \"npm:scraper\" \"npm:dev\"",
    "build": "vite build && tsx scripts/generate-static-part-pages.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "lint": "tsc --noEmit",
    "test": "tsx scripts/test-decoder.ts && tsx scripts/test-p0-safety.ts && tsx scripts/test-static-metadata.ts",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.1.14",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "fuse.js": "^7.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.4",
    "radix-ui": "^1.6.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
