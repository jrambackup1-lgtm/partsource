# PartSource — local development configuration.
# Copy to .env.local and edit as needed.

# Where the frontend looks for the optional Zoro pricing scraper.
#
# LOCAL DEV:  http://localhost:3001   (run `npm run scraper` in another shell)
# PRODUCTION: the URL of the hosted scraper (Fly.io / Render), e.g.
#             https://partsource-scraper.fly.dev  or
#             https://partsource-scraper.onrender.com
#
# In CI/production, set this as a GitHub Actions / Pages build variable so it
# is baked into the static bundle at build time. When unset, the frontend
# silently falls back to estimated prices.
VITE_SCRAPER_URL=http://localhost:3001

# Port the scraper itself listens on. Render/Fly inject PORT automatically.
SCRAPER_PORT=3001

# --- Scraper runtime tuning (optional; defaults shown) ---
# CACHE_TTL_SECONDS=21600      # in-memory cache TTL for Zoro lookups (6h)
# FETCH_TIMEOUT_SECONDS=15     # per-request timeout to Zoro
# CB_FAILURE_THRESHOLD=8       # failures within window that trip the breaker
# CB_WINDOW_SECONDS=300        # circuit-breaker rolling window (5m)
# CB_COOLDOWN_SECONDS=120      # breaker stays open this long once tripped (2m)
